# OpenClaw 远端回归（脱敏模板）
# 说明：真实值请写入 .env.openclaw.local，以下文件仅为入库模板，不含凭据

VPS_USER=<vps-user>
VPS_HOST=<vps-host>
VPS_PASSWORD=<REDACTED>
VPS_PORT=6069

MACMINI_USER=<macmini-user>
MACMINI_HOST=<macmini-host-or-127.0.0.1>
MACMINI_PASSWORD=<REDACTED>
MACMINI_PORT=2222
MACMINI_DATAPULSE_DIR=$HOME/.openclaw/workspace/DataPulse

REMOTE_PYTHON=python3
REMOTE_PYTHON_MIN_VERSION=3.10
REMOTE_AUTOPICK_PYTHON=1
REMOTE_BOOTSTRAP_INSTALL=1
PLATFORMS="twitter reddit bilibili telegram xhs youtube"
MIN_CONFIDENCE=0.0
RUN_ID=<optional-run-id>
OUT_DIR=./artifacts

URL_1=https://beewebsystems.com/
URL_BATCH="https://chatprd.ai/ https://beewebsystems.com/ https://uxpilot.ai/"
DATAPULSE_SMOKE_TWITTER_URL=https://x.com/everestchris6/status/2025995047729254701
DATAPULSE_SMOKE_REDDIT_URL=
DATAPULSE_SMOKE_YOUTUBE_URL=
DATAPULSE_SMOKE_BILIBILI_URL=
DATAPULSE_SMOKE_TELEGRAM_URL=
DATAPULSE_SMOKE_RSS_URL=
DATAPULSE_SMOKE_WECHAT_URL=
DATAPULSE_SMOKE_XHS_URL=
