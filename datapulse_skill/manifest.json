{
  "name": "DataPulse",
  "description": "Cross-platform information intake and confidence-normalized memory sink for assistant and agent workflows.",
  "version": "0.7.0",
  "author": "DataPulse",
  "entry_point": "datapulse_skill",
  "args": {
    "text": {
      "type": "string",
      "description": "Raw user message that may contain one or more URLs.",
      "required": true
    }
  },
  "triggers": [
    {
      "type": "message",
      "pattern": "(?i)(?:read|fetch|save|summary|summarize|extract|parse|/read|/save)\\s+https?://",
      "description": "Triggered for URL ingestion requests."
    },
    {
      "type": "message",
      "pattern": "(?i)\\bsearch\\b.*(?:web|trending|trend|topic|资讯|搜索|热搜)",
      "description": "Triggered for topical search and trend discovery requests."
    },
    {
      "type": "message",
      "pattern": "(?i)\\b(datapulse|skill|agent)\\b.*\\b(health|doctor|config|diagnose|update|version|upgrade|troubleshoot)\\b",
      "description": "Triggered for maintenance and capability introspection tasks."
    },
    {
      "type": "message",
      "pattern": "(?i)(?:datapulse|data.?pulse)\\b.*\\b(help|usage|contract|能力|命令)\\b",
      "description": "Triggered for user requests about usage/help/contract output."
    }
  ],
  "memory_path": "../../memory/inbox/",
  "capabilities": [
    "content-extraction",
    "cross-platform-sources",
    "confidence-scoring",
    "json-memory",
    "markdown-memory",
    "assistant-ready",
    "mcp-tools"
  ],
  "tags": ["datapulse", "web-reader", "assistant", "agent", "mcp", "confidence"]
}
