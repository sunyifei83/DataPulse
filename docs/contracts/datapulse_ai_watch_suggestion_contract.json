{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datapulse/contracts/datapulse_ai_watch_suggestion_contract.v1.schema.json",
  "title": "DataPulse AI Watch Suggestion Payload Contract",
  "description": "Structured output contract for L16.4 watch suggestion payloads. Missing contract lookup or validation failure must fail closed to manual or deterministic behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_id",
    "surface",
    "output_kind",
    "subject",
    "payload"
  ],
  "x-datapulse-governance": {
    "phase": "L16.4",
    "validation_mode": "fail_closed",
    "on_missing_contract": "reject_and_fallback",
    "on_validation_error": "reject_and_fallback"
  },
  "properties": {
    "contract_id": {
      "const": "datapulse_ai_watch_suggestion.v1"
    },
    "surface": {
      "const": "mission_suggest"
    },
    "output_kind": {
      "const": "suggestion"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "const": "WatchMission"
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "run_readiness"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "proposed_query": {
          "type": "string",
          "minLength": 1
        },
        "candidate_sites": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "scope_entities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "scope_topics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "scope_regions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "operator_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "run_readiness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reasons"
          ],
          "properties": {
            "status": {
              "enum": [
                "ready",
                "needs_review",
                "blocked"
              ]
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "blocking_facts": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "proposed_query"
          ]
        },
        {
          "required": [
            "candidate_sites"
          ]
        },
        {
          "required": [
            "scope_entities"
          ]
        },
        {
          "required": [
            "scope_topics"
          ]
        },
        {
          "required": [
            "scope_regions"
          ]
        }
      ]
    }
  }
}
