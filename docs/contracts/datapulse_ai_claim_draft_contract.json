{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datapulse/contracts/datapulse_ai_claim_draft_contract.v1.schema.json",
  "title": "DataPulse AI Claim Draft Payload Contract",
  "description": "Structured output contract for L16.4 claim draft payloads. Missing contract lookup or validation failure must fail closed instead of introducing freeform claim text into governed report flows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_id",
    "surface",
    "output_kind",
    "subject",
    "payload"
  ],
  "x-datapulse-governance": {
    "phase": "L16.4",
    "validation_mode": "fail_closed",
    "on_missing_contract": "reject_and_fallback",
    "on_validation_error": "reject_and_fallback"
  },
  "properties": {
    "contract_id": {
      "const": "datapulse_ai_claim_draft.v1"
    },
    "surface": {
      "const": "claim_draft"
    },
    "output_kind": {
      "const": "draft"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "enum": [
            "Story",
            "ReportBrief",
            "ClaimCard"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "claim_cards"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence_intake": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "story",
            "summary",
            "evidence_status",
            "source_item_ids",
            "source_urls",
            "source_refs",
            "evidence_inputs"
          ],
          "properties": {
            "story": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                }
              }
            },
            "summary": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "evidence_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "primary_evidence_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "secondary_evidence_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "source_item_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "source_url_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "source_ref_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "stitched_evidence_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "cross_validated_evidence_count": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "evidence_status": {
              "enum": [
                "bound",
                "partial",
                "missing"
              ]
            },
            "source_item_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "source_urls": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "source_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "evidence_inputs": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "citation_bundle_candidates": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          }
        },
        "citation_bundle_candidates": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "research_projection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source_plan": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "summary",
                "deep",
                "news"
              ],
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "provider_hints": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                },
                "platforms": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                },
                "sites": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                },
                "time_range": {
                  "type": "string"
                },
                "deep": {
                  "type": "boolean"
                },
                "news": {
                  "type": "boolean"
                }
              }
            },
            "coverage_gap": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "summary",
                "reasons",
                "operator_action"
              ],
              "properties": {
                "status": {
                  "enum": [
                    "clear",
                    "watch",
                    "review_required",
                    "blocked"
                  ]
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "reasons": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                },
                "operator_action": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "claim_cards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "statement",
              "confidence",
              "status",
              "source_item_ids",
              "governance"
            ],
            "properties": {
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "brief_id": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              },
              "confidence": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "status": {
                "enum": [
                  "draft",
                  "review"
                ]
              },
              "citation_bundle_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "source_item_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1,
                "uniqueItems": true
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "governance": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "evidence_status",
                  "contradictions"
                ],
                "properties": {
                  "evidence_status": {
                    "enum": [
                      "bound",
                      "partial",
                      "missing"
                    ]
                  },
                  "contradictions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "topic",
                        "severity",
                        "note"
                      ],
                      "properties": {
                        "topic": {
                          "type": "string",
                          "minLength": 1
                        },
                        "severity": {
                          "enum": [
                            "warning",
                            "error"
                          ]
                        },
                        "note": {
                          "type": "string",
                          "minLength": 1
                        }
                      }
                    }
                  },
                  "unresolved_flags": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "uniqueItems": true
                  },
                  "evidence_intake": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "story_id": {
                        "type": "string"
                      },
                      "story_title": {
                        "type": "string"
                      },
                      "evidence_count": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "source_ref_count": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "source_refs": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        },
                        "uniqueItems": true
                      },
                      "stitched_evidence_count": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "cross_validated_evidence_count": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "citation_candidate_count": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "source_url_count": {
                        "type": "integer",
                        "minimum": 0
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
